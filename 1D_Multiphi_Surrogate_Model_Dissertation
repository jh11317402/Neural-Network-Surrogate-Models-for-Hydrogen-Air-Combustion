    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F #moves data forward in function\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "dc8b9bc5-f4e7-4bb5-b811-646d8d431e97",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create Model Class that inherits nn.Module\n",
    "class Model(nn.Module): #class = neural network, doing nn.Module means it is able to use all of these features\n",
    "    #input layer with 4 features --> hidden layer 1 --> hidden layer 2 --> single output\n",
    "    def __init__(self, in_features=4, h1=64, h2=32, out_features=1): #creates layers\n",
    "        super().__init__() #sets up parent class initialisation of nn.Module\n",
    "        self.fc1 = nn.Linear(in_features, h1) #creating hidden layer 1 here with in_features number of inputs and h1 number of outputs\n",
    "        self.fc2 = nn.Linear(h1,h2) \n",
    "        self.out = nn.Linear(h2,out_features) #even for nonlinear datasets, nn.Linear is the choice here, just need to add activation later\n",
    "    def forward(self,x): #function which moves data through network, x is the variable here which gets moved through\n",
    "        x = F.relu(self.fc1(x)) #Activation ReLU function (Rectified Linear Unit)\n",
    "        x = F.relu(self.fc2(x)) \n",
    "        x = self.out(x) #No activation function on final layer\n",
    "        return x"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d8aed8ea-fa11-4103-9c37-2bf9953990ad",
   "metadata": {},
   "outputs": [],
   "source": [
    "torch.manual_seed(10)\n",
    "model = Model() #create model"
   ]
